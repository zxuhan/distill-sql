# OpenAI API key, used for teacher generation and reference eval.
OPENAI_API_KEY=sk-...

# Optional: override teacher model. Default: gpt-4o-mini-2024-07-18
# DISTILL_SQL_TEACHER_MODEL=gpt-4o-mini-2024-07-18

# Optional: override max cumulative spend (USD). Default: 50.
# DISTILL_SQL_MAX_SPEND_USD=50

# Optional: HF cache dir override.
# HF_HOME=~/.cache/huggingface
